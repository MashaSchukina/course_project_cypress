{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": [
      "id",
      "hist_id",
      "date",
      "version"
    ],
    "additionalProperties": false,
    "properties": {
      "id": {
        "type": "integer",
        "minimum": 1
      },
      "hist_id": {
        "type": "string"
        
      },
      "date": {
        "type": "integer",
        "minimum": 1000000000000
      },
      "version": {
        "type": "object",
        "required": [
          "object_type",
          "object_id",
          "workspace_id",
          "operation",
          "data",
          "master_id",
          "version",
          "deleted",
          "traceparent",
          "date_created",
          "date_updated",
          "event_publish_time"
        ],
        "additionalProperties": false,
        "properties": {
          "object_type": {
            "type": "string",
            "enum": ["comment"]
          },
          "object_id": {
            "type": "string",
            "pattern": "^[0-9]+$"
          },
          "workspace_id": {
            "type": "integer",
            "minimum": 1
          },
          "operation": {
            "type": "string",
            "maxLength": 1
          },
          "master_id": {
            "type": "integer"
          },
          "version": {
            "type": "integer"
          },
          "deleted": {
            "type": "boolean"
          },
          "traceparent": {
            "type": "string",
            "pattern": "^[0-9]+$"
          },
          "date_created": {
            "type": "integer",
            "minimum": 1000000000000
          },
          "date_updated": {
            "type": "integer",
            "minimum": 1000000000000
          },
          "event_publish_time": {
            "type": "integer",
            "minimum": 1000000000000
          },
          "data": {
            "type": "object",
            "required": [
              "context",
              "relationships",
              "changes"
            ],
            "additionalProperties": false,
            "properties": {
              "context": {
                "type": "object",
                "required": [
                  "user_id",
                  "root_parent_type",
                  "is_chat",
                  "audit_context",
                  "originating_service"
                ],
                "additionalProperties": false,
                "properties": {
                  "user_id": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "root_parent_type": {
                    "type": "integer"
                  },
                  "is_chat": {
                    "type": "boolean"
                  },
                  "originating_service": {
                    "type": "string"
                  },
                  "audit_context": {
                    "type": "object",
                    "required": [
                      "userid",
                      "current_time",
                      "route"
                    ],
                    "additionalProperties": false,
                    "properties": {
                      "userid": {
                        "type": "integer",
                        "minimum": 1
                      },
                      "current_time": {
                        "type": "integer",
                        "minimum": 1000000000000
                      },
                      "route": {
                        "type": "string"
                      }
                    }
                  }
                }
              },
              "relationships": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": [
                    "type",
                    "object_type",
                    "object_id",
                    "workspace_id"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "type": {
                      "type": "string"
                    },
                    "object_type": {
                      "type": "string"
                    },
                    "object_id": {
                      "type": "string",
                      "pattern": "^[0-9]+$"
                    },
                    "workspace_id": {
                      "type": "integer",
                      "minimum": 1
                    }
                  }
                }
              },
              "changes": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "field",
                    "after"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "field": {
                      "type": "string"
                    },
                    "after": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
